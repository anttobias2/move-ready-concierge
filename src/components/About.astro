---
// src/components/About.astro
import { base } from 'astro:config/client';
---

<header>
  <div class="container nav">
    <div class="logo">
      <img src={`${base}/favicon.png`} alt="Move-Ready Concierge Logo" width="56" height="56" />
      Move Ready Concierge
    </div>

    <nav id="navLinks">
      <a href={`${base}/`}>Home</a>
      <a href={`${base}about`}>About</a>
      <a href={`${base}process`}>How It Works</a>
      <a href={`${base}services`}>Services</a>
      <a href={`${base}/#contact`}>Contact</a>
      <a href={`${base}/#book`} class="btn-primary">Book Now</a>
    </nav>

    <div class="hamburger" id="hamburger"><span></span><span></span><span></span></div>
  </div>
</header>

<main>
  <section class="hero-about">
    <div class="container">
      <h1>About Move Ready Concierge</h1>
      <p>Founded on the belief that moving should be exciting, not exhausting.</p>
    </div>
  </section>

  <section class="container">
    <div class="section-title">
      <h2>Our Story</h2>
      <p>Transforming the moving experience one client at a time</p>
    </div>

    <div class="story-content">
      <p>
        Move Ready Concierge was born from a simple observation: moving is one of life's most 
        stressful events, yet it doesn't have to be. After experiencing countless chaotic moves 
        ourselves and watching friends and family struggle with the endless logistics, we knew 
        there had to be a better way.
      </p>
      <p>
        We created Move Ready Concierge to be the calm, capable partner you need during this 
        transition. Our white-glove service replaces stress with structure, chaos with coordination, 
        and anxiety with assurance.
      </p>
    </div>
  </section>

  <section class="container">
    <div class="section-title">
      <h2>Our Values</h2>
      <p>What drives us every day</p>
    </div>

    <div class="grid">
      <div class="card">
        <div class="value-icon">🎯</div>
        <h3>Precision</h3>
        <p>Every detail matters. We plan meticulously and execute flawlessly so nothing falls through the cracks.</p>
      </div>
      <div class="card">
        <div class="value-icon">🤝</div>
        <h3>Trust</h3>
        <p>We've built relationships with the best vendors in the business. Your belongings and your time are in expert hands.</p>
      </div>
      <div class="card">
        <div class="value-icon">💎</div>
        <h3>Excellence</h3>
        <p>We don't just meet expectations—we exceed them. Your satisfaction is our benchmark for success.</p>
      </div>
      <div class="card">
        <div class="value-icon">🧘</div>
        <h3>Peace of Mind</h3>
        <p>Moving is complex. Our job is to make it feel simple, allowing you to stay focused on what matters most.</p>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-title">
      <h2>Why Choose Us?</h2>
      <p>The Move Ready difference</p>
    </div>

    <div class="grid why-grid">
      <div class="card why-card">
        <h3>✓ Vetted Network</h3>
        <p>We work exclusively with licensed, insured, and proven service providers who share our commitment to excellence.</p>
      </div>
      <div class="card why-card">
        <h3>✓ One Point of Contact</h3>
        <p>No more juggling phone calls and emails. We coordinate everything, so you have a single, reliable source for updates and decisions.</p>
      </div>
      <div class="card why-card">
        <h3>✓ Transparent Pricing</h3>
        <p>No hidden fees or surprise charges. You'll know exactly what to expect from our initial consultation through completion.</p>
      </div>
      <div class="card why-card">
        <h3>✓ Local Expertise</h3>
        <p>We know the Greater Seattle Area inside and out—from parking restrictions to the best times to move in each neighborhood.</p>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="cta">
      <h2>Ready to Experience the Difference?</h2>
      <p>Let's make your move the smoothest one yet.</p>
      <a href={`${base}/#book`} class="btn-primary">Schedule Your Consultation</a>
    </div>
  </section>
</main>

<footer>
  <div class="container">© <span id="year"></span> Move Ready Concierge — Making your move feel like home</div>
</footer>

<script>
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('navLinks');
  const year = document.getElementById('year');

  if (hamburger && navLinks) {
    hamburger.addEventListener('click', () => {
      navLinks.classList.toggle('open');
    });
  }

  if (year) {
    year.textContent = new Date().getFullYear().toString();
  }
</script>

<style>
  :root {
    --primary: #1e3a5f;
    --accent: #f59e0b;
    --accent-light: #fbbf24;
    --accent-soft: rgba(245,158,11,0.12);
    --warm: #fffbeb;
    --warm-mid: #fef3c7;
    --bg: #ffffff;
    --muted: #64748b;
    --border: #e2e8f0;
    --radius: 20px;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: 'Inter', system-ui, sans-serif;
    background: #ffffff;
    color: var(--primary);
    line-height: 1.7;
  }

  a { text-decoration: none; color: inherit; }

  .container {
    max-width: 1100px;
    margin: auto;
    padding: 4rem 1.25rem;
  }

  header {
    position: sticky;
    top: 0;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(245,158,11,0.15);
    z-index: 1000;
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 80px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-weight: 700;
    font-family: 'Sora', sans-serif;
    letter-spacing: -0.02em;
    font-size: 1.1rem;
    color: var(--primary);
  }

  nav {
    display: flex;
    gap: 2rem;
    align-items: center;
    font-weight: 500;
  }

  nav a:hover { 
    color: var(--accent);
    transition: color 0.3s ease;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), var(--accent-light));
    color: white;
    padding: 0.8rem 1.6rem;
    border-radius: 50px;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(245,158,11,0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(245,158,11,0.4);
  }

  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
  .hamburger span { width: 26px; height: 3px; background: var(--primary); border-radius: 4px; }

  @media (max-width: 768px) {
    nav {
      position: absolute;
      top: 80px;
      left: 0;
      right: 0;
      background: rgba(255,255,255,0.98);
      flex-direction: column;
      padding: 1.5rem;
      display: none;
      border-bottom: 1px solid var(--border);
      gap: 1rem;
    }

    nav.open { display: flex; }
    .hamburger { display: flex; }
  }

  .hero-about {
    padding: 8rem 0 6rem;
    text-align: center;
    background: linear-gradient(135deg, var(--primary), #2d5a8f);
    color: white;
  }

  .hero-about h1 {
    font-family: 'Sora', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.6rem);
    margin-bottom: 1.2rem;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  .hero-about p {
    font-size: 1.25rem;
    opacity: 0.95;
    max-width: 600px;
    margin: 0 auto;
  }

  section { padding: 5.5rem 0; }

  .section-title { 
    text-align: center; 
    margin-bottom: 3.5rem; 
  }
  
  .section-title h2 { 
    font-family: 'Sora', sans-serif;
    font-size: 2.4rem; 
    margin-bottom: 0.8rem;
    color: var(--primary);
    font-weight: 700;
  }
  
  .section-title p { 
    color: var(--muted); 
    font-size: 1.1rem;
  }

  .story-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .story-content p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .why-grid {
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  }

  .card {
    background: #ffffff;
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 35px rgba(245,158,11,0.15);
    border-color: var(--accent-soft);
  }

  .value-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    display: block;
  }

  .card h3 {
    font-family: 'Sora', sans-serif;
    color: var(--primary);
    margin-bottom: 0.8rem;
    font-size: 1.25rem;
  }

  .card p {
    color: var(--muted);
    line-height: 1.7;
  }

  .why-card h3 {
    color: var(--accent);
  }

  .cta {
    background:
      linear-gradient(135deg, rgba(245,158,11,0.08), transparent),
      linear-gradient(135deg, var(--primary), #2d5a8f);
    color: white;
    border-radius: var(--radius);
    padding: 6rem 2.5rem;
    text-align: center;
    box-shadow: 0 20px 60px rgba(30,58,95,0.25);
  }

  .cta h2 { 
    font-family: 'Sora', sans-serif;
    font-size: 2.6rem; 
    margin-bottom: 1.2rem;
    font-weight: 700;
  }
  
  .cta p { 
    opacity: 0.95; 
    margin-bottom: 2.8rem;
    font-size: 1.15rem;
  }

  footer {
    padding: 3rem 0;
    text-align: center;
    color: var(--muted);
    font-size: 0.95rem;
    background: #ffffff;
    border-top: 1px solid var(--border);
  }

  html { scroll-behavior: smooth; }

  ::selection {
    background: var(--accent-soft);
    color: var(--primary);
  }
</style>